[Unit]
Description=Zramdedup KSM Governor and Memory Scanner
Documentation=https://github.com/animaios/animaksm
After=local-fs.target
ConditionPathExists=/sys/kernel/mm/ksm

[Service]
Type=simple
ExecStart=/usr/local/bin/zramdedup run --config /etc/zramdedup.toml
ExecStopPost=-/usr/local/bin/zramdedup restore-ksm --config /etc/zramdedup.toml
Restart=on-failure
RestartSec=5

# Security: limit what the process can do outside KSM tuning.
NoNewPrivileges=yes
AmbientCapabilities=CAP_SYS_PTRACE CAP_DAC_READ_SEARCH
CapabilityBoundingSet=CAP_SYS_PTRACE CAP_DAC_READ_SEARCH
ProtectSystem=strict
ProtectHome=yes
PrivateTmp=yes
# /sys/kernel/mm/ksm must be read-write for governor + scanner
ReadWritePaths=/var/lib/zramdedup /sys/kernel/mm/ksm
ReadOnlyPaths=/proc/pressure /etc/zramdedup.toml
RestrictNamespaces=yes
LockPersonality=yes
MemoryDenyWriteExecute=no
RemoveIPC=yes

# Resource limits
MemoryMax=32M
Nice=19

[Install]
WantedBy=multi-user.target
